    {
      "name": "Doctor Availability",
      "item": [
        {
          "name": "Add/Update Availability",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorId\": \"DOCTOR_ID_HERE\",\n  \"dayOfWeek\": 1,\n  \"startTime\": \"09:00\",\n  \"endTime\": \"17:00\",\n  \"slotDuration\": 30\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/doctor/availability",
              "host": ["{{baseUrl}}"],
              "path": ["api", "doctor", "availability"]
            },
            "description": "dayOfWeek: 0=Sunday, 1=Monday, ..., 6=Saturday"
          }
        },
        {
          "name": "Get Doctor Slots",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/doctors/:doctorId/slots?date=2024-01-01",
              "host": ["{{baseUrl}}"],
              "path": ["api", "doctors", ":doctorId", "slots"],
              "variable": [
                {
                  "key": "doctorId",
                  "value": "DOCTOR_ID_HERE"
                }
              ],
              "query": [
                {
                  "key": "date",
                  "value": "2024-01-01"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Appointments",
      "item": [
        {
          "name": "Book Appointment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorId\": \"DOCTOR_ID_HERE\",\n  \"visitType\": \"online\",\n  \"patientName\": \"Patient Name\",\n  \"patientPhone\": \"1234567890\",\n  \"patientEmail\": \"patient@example.com\",\n  \"serviceRequired\": \"Consultation\",\n  \"date\": \"2024-01-01\",\n  \"time\": \"09:00\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/appointments/book",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments", "book"]
            },
            "description": "Public endpoint for booking appointments without login"
          }
        },
        {
          "name": "Cancel Appointment",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/appointments/:id/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments", ":id", "cancel"],
              "variable": [
                {
                  "key": "id",
                  "value": "APPOINTMENT_ID_HERE"
                }
              ]
            }
          }
        },
        {
          "name": "Get Doctor Appointments",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/doctors/:doctorId/appointments?date=2024-01-01",
              "host": ["{{baseUrl}}"],
              "path": ["api", "doctors", ":doctorId", "appointments"],
              "variable": [
                {
                  "key": "doctorId",
                  "value": "DOCTOR_ID_HERE"
                }
              ],
              "query": [
                {
                  "key": "date",
                  "value": "2024-01-01",
                  "disabled": true
                }
              ]
            }
          }
        }
      ]
